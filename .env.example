# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# NEVER commit .env to git (.gitignore already excludes it)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Groq (Inference LLM + Build LLM) ────────────────────────────────────────
# Get free API key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Inference model (used by app.py at query time)
GROQ_MODEL=llama-3.3-70b-versatile

# Build model (used by build_index.py for entity extraction — faster + cheaper)
GROQ_BUILD_MODEL=llama-3.1-8b-instant

# ─── Qdrant Cloud (Vector Store) ─────────────────────────────────────────────
# Step 1: Sign up at https://cloud.qdrant.io
# Step 2: Create a cluster (GCP freemium or any region)
# Step 3: Go to "API Keys" → create a key → paste below
# Step 4: Copy the cluster endpoint URL (format: https://<id>.<region>.gcp.cloud.qdrant.io)
QDRANT_URL=https://your-cluster-id.region.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Collection name — LightRAG auto-creates this on first build_index.py run
# Use lowercase with underscores, e.g. f16_lightrag or lightrag_vectors
QDRANT_COLLECTION_NAME=f16_lightrag

# Cosine similarity threshold (0.0–1.0). Lower = more results, less precise.
# 0.2 works well for nomic-embed-text-v1.5 on technical documents.
QDRANT_COSINE_THRESHOLD=0.2

# ─── Neo4j Aura (Graph Store) ─────────────────────────────────────────────────
# Step 1: Go to https://console.neo4j.io → New Instance → AuraDB Free
# Step 2: Download the credentials file — you get URI, username, password
# Step 3: Paste below
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_aura_password_here
NEO4J_DATABASE=neo4j

# ─── LightRAG Storage (local working dir for cache + pipeline status) ─────────
# No FAISS files are stored here — only LLM response cache and metadata.
RAG_WORKING_DIR=./lightrag_qdrant_storage

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── OpenRouter (optional — evaluation only) ──────────────────────────────────
# Only needed if running eval/eval_script.py with an OpenRouter judge model
# OPENROUTER_API_KEY=your_openrouter_key_here
